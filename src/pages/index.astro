---
import PokemonCard from "../components/PokemonCard.astro";
import PokemonModal from "../components/PokemonModal.astro";
import Searchbar from "../components/SearchBar.astro";
import Filters from "../components/Filters.astro";
import "../styles/global.css";

const listRes = await fetch("https://pokeapi.co/api/v2/pokemon?limit=151");
const { results } = await listRes.json();

const pokemons = await Promise.all(
  results.map((p) => fetch(p.url).then((r) => r.json()))
);
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Pokédex</title>
	<link rel="preconnect" href="https://fonts.googleapis.com" />
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
	<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  	<body>
		<header>
		<h1>Pokédex</h1>
		<div class="toggle-container">
			<span id="toggle-icon">☀️</span>
			<label class="switch">
			<input type="checkbox" id="dark-toggle" />
			<span class="slider"></span>
			</label>
			<span>🌙</span>
		</div>
		</header>
	<Searchbar />	
	<Filters />
	<main>
		{pokemons.map((pokemon, index) => (
			<PokemonCard pokemon={pokemon} index={index} />
		))}
	</main>
	<PokemonModal />
</div>

<script>
  const cards = document.querySelectorAll(".card");
  const modal = document.getElementById("modal");
  const modalBody = document.getElementById("modal-body");
  const closeBtn = document.getElementById("close-modal");
  const search = document.getElementById("search");
  const darkToggle = document.getElementById("dark-toggle");

  // Intersection Observer
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        const card = entry.target;
        card.style.animationDelay = `${card.dataset.delay}ms`;
        card.classList.add("visible");
        observer.unobserve(card);
      }
    });
  }, { threshold: 0.1 });

  cards.forEach((card) => {
    card.style.animationDelay = "9999s";
    observer.observe(card);
  });

  // Click en cards
  cards.forEach((card) => {
    card.addEventListener("click", () => {
      const data = JSON.parse(card.dataset.pokemon);

		modalBody.innerHTML = `
			<img src="${data.sprites.other['official-artwork'].front_default || data.sprites.front_default}" alt="${data.name}" style="width:180px;height:180px;" />
			<span class="modal-number">#${String(data.id).padStart(3, '0')}</span>
			<h2 class="modal-name">${data.name}</h2>
			<div class="modal-types">
				${data.types.map(t => `<span class="type type-${t.type.name}">${t.type.name}</span>`).join("")}
			</div>
			<div class="modal-meta">
				<div class="meta-item">
				<span class="meta-label">Altura</span>
				<span class="meta-value">${data.height / 10}m</span>
				</div>
				<div class="meta-item">
				<span class="meta-label">Peso</span>
				<span class="meta-value">${data.weight / 10}kg</span>
				</div>
			</div>
			<div class="modal-section">
				<h3>Habilidades</h3>
				<div class="abilities">
				${data.abilities.map(a => `<span class="ability">${a.ability.name}</span>`).join("")}
				</div>
			</div>
			<div class="modal-section">
				<h3>Stats</h3>
				${data.stats.map(s => `
				<div class="stat-row">
					<span class="stat-name">${s.stat.name}</span>
					<span class="stat-value">${s.base_stat}</span>
					<div class="stat-bar">
					<div class="stat-fill" style="width: ${Math.min(s.base_stat / 255 * 100, 100)}%"></div>
					</div>
				</div>
				`).join("")}
			</div>
			<div class="modal-section">
				<h3>Movimientos</h3>
				<div class="moves">
				${data.moves.slice(0, 20).map(m => `<span class="move">${m.move.name}</span>`).join("")}
				</div>
			</div>
		`;

      const content = document.querySelector(".modal-content");
      content.style.animation = "none";
      content.offsetHeight;
      content.style.animation = "";

      modal.classList.remove("hidden");
    });
  });

  // Cerrar modal
  closeBtn.addEventListener("click", () => modal.classList.add("hidden"));
  modal.addEventListener("click", (e) => {
    if (e.target === modal) modal.classList.add("hidden");
  });

  // Búsqueda
  search.addEventListener("input", () => {
    const query = search.value.toLowerCase();
    cards.forEach((card) => {
      const name = card.querySelector("h2").textContent.toLowerCase();
      if (name.includes(query)) {
        card.classList.remove("hidden");
        card.style.display = "flex";
        card.style.animationDelay = query === "" ? `${card.dataset.delay}ms` : "0ms";
      } else {
        card.classList.add("hidden");
        setTimeout(() => {
          if (card.classList.contains("hidden")) card.style.display = "none";
        }, 200);
      }
    });
  });

  // Dark mode
  darkToggle.addEventListener("change", () => {
    document.documentElement.classList.toggle("dark");
    cards.forEach((card) => {
      card.style.animation = "none";
      card.offsetHeight;
      card.style.animation = "";
      card.style.animationDelay = "0ms";
    });
  });
  const filterBtns = document.querySelectorAll(".filter-btn");

filterBtns.forEach(btn => {
  btn.addEventListener("click", () => {
    filterBtns.forEach(b => b.classList.remove("active"));
    btn.classList.add("active");

    const type = btn.dataset.type;
    cards.forEach(card => {
	if (type === "all" || card.dataset.type === type) {
	card.style.display = "flex";
	card.classList.remove("hidden");
	card.style.transition = "none";
	card.style.animation = "none";
	card.style.animationDelay = "0ms";
	card.style.opacity = "1";
	card.style.transform = "none";
	}
	else {
        card.style.display = "none";
      }
    });
  });
});
</script>
  </body>
</html>
